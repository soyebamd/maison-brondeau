          "settings": {
            "heading": "When is Maison Brondeau open? ",
            "icon": "none",
            "row_content": "<p>Maison Brondeau is open 6 days a week, Tuesday through Sunday, and also offers free Local Delivery throughout all of Westchester. Just select Local Delivery at checkout and your items will be brought right to your doorstep free of charge!</p>",
            "page": ""
          }
